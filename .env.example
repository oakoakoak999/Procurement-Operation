# Odoo credentials
ODOO_USERNAME=your_odoo_username
ODOO_PASSWORD=your_odoo_password

# Google OAuth — same credentials for Drive + Sheets (tnp.phr@gmail.com)
GDRIVE_CLIENT_ID=your_client_id
GDRIVE_CLIENT_SECRET=your_client_secret

# GitHub personal access token — for GitHub REST API / gh CLI (repo + workflow scope)
# Used to list/trigger GitHub Actions and read run status locally. Never commit the real value.
GH_TOKEN=your_github_pat

# Cloudflare Access service token — ONLY needed to reach Odoo UAT from an
# untrusted datacenter/cloud IP (e.g. GitHub-hosted runner). Leave BOTH unset on
# a Cloudflare-trusted inside-network machine; the scripts send no CF headers then.
# Get the pair from IT (Access → Service Auth). Sent as CF-Access-Client-Id /
# CF-Access-Client-Secret headers on every Odoo request.
CF_ACCESS_CLIENT_ID=your_cf_access_client_id
CF_ACCESS_CLIENT_SECRET=your_cf_access_client_secret

# Machine-specific local paths
OBSIDIAN_VAULT_PATH=C:\Users\YourUsername\Desktop\Obsidian Vault
CLAUDE_MD_PATH=C:\Users\YourUsername\CLAUDE.md

# Google Drive folder IDs (machine-specific — check with Oak for correct values)
OBSIDIAN_BRAIN_FOLDER_ID=13FhD4f-ByWUyMx89HsVzzEuSW4be4x5n
CLAUDE_MD_FOLDER_ID=11de3g5uVMrQJwUeluNpTrPvpCxSOBdbv
OBSIDIAN_VAULT_FOLDER_ID=11de3g5uVMrQJwUeluNpTrPvpCxSOBdbv
